# Обязательно: токен от @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# --- AI ---

# OpenCode Zen (OpenAI-совместимый API)
# Получить ключ: https://opencode.ai (раздел API Keys)
AI_PROVIDER=opencode_zen
OPENCODE_ZEN_API_KEY=sk-your-opencode-zen-key
# OPENCODE_ZEN_MODEL=deepseek-v4-flash-free  # модель по желанию

# --- Альтернативы ---

# Google Gemini (бесплатно, без карты)
# Получить ключ: https://aistudio.google.com/apikey
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key

# Поиск в интернете (без AI и без ключей)
# AI_PROVIDER=web
